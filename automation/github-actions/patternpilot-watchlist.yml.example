name: Patternpilot Watchlist Automation

on:
  workflow_dispatch:
  schedule:
    - cron: "15 5 * * *"

jobs:
  patternpilot:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - uses: actions/setup-node@v4
        with:
          node-version: 20

      - name: Show scheduler readiness
        run: npm run automation:jobs

      - name: Dispatch next Patternpilot job
        env:
          PATTERNPILOT_GITHUB_TOKEN: ${{ secrets.PATTERNPILOT_GITHUB_TOKEN }}
        run: npm run automation:dispatch

      - name: Publish automation alerts to GitHub summary
        if: always()
        run: npm run automation:alerts -- --target github-summary
